{
  "name": "forge-workspace",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @forge/web dev",
    "build": "pnpm run build:web && pnpm run build:cli",
    "build:web": "pnpm --filter @forge/web build",
    "build:cli": "pnpm --filter @forge/cli build",
    "start": "pnpm --filter @forge/web start",
    "test": "pnpm run test:web && pnpm run test:cli",
    "test:web": "pnpm --filter @forge/web test",
    "test:cli": "pnpm --filter @forge/cli test",
    "doctor": "pnpm --filter @forge/web doctor"
  }
}
